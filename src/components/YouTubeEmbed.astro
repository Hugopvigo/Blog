---
type Props = {
  url: string;
  label: string;
};

const { url, label } = Astro.props;
---

<div>
  <iframe
    class="aspect-video w-full"
    src={url}
    title={label}
    frameborder="0"
    sandbox="allow-scripts allow-same-origin allow-presentation"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
  >
  </iframe>
</div>

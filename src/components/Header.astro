---
import Nav from "./Nav.astro";
import DarkModeToggle from "./DarkModeToggle.astro";
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-bg-body/90 border-b border-text-muted/10">
  <a
    class="unset absolute z-10 left-[50%] -top-[100rem] translate-x-[-50%] bg-white dark:bg-slate-900 text-black dark:text-white px-8 py-2 focus:top-2"
    href="#main"
  >
    Skip to content
  </a>
  <Nav />
  <div class="justify-self-end py-2 flex items-center gap-3 text-text-muted">
    <a
      class="unset hover:text-primary-yellow transition-colors duration-150"
      href="https://github.com/Hugopvigo"
      target="_blank"
      rel="noopener noreferrer"
      title="Hugo en GitHub"
    >
      <i class="fa-brands fa-github text-lg" aria-hidden="true"></i>
      <span class="sr-only">GitHub</span>
    </a>
    <a
      class="unset hover:text-primary-blue transition-colors duration-150"
      href="https://twitter.com/hugopvigo"
      target="_blank"
      rel="noopener noreferrer"
      title="Hugo en Twitter"
    >
      <i class="fa-brands fa-twitter text-lg" aria-hidden="true"></i>
      <span class="sr-only">Twitter</span>
    </a>
  </div>
  <DarkModeToggle />
</header>
<style>
  header {
    grid-area: header;
    display: grid;
    align-items: center;
    grid-template-columns: minmax(0, 1fr) minmax(0, max-content) minmax(
      0,
      max-content
    );
  }
</style>

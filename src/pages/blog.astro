---
import { getCollection } from "astro:content";
import PageLayout from "../layouts/PageLayout.astro";
import PageMeta from "../components/PageMeta.astro";
import { SITE_TITLE, formatDate } from "../config";

const posts = await getCollection("blog", ({ data }) => !data.draft);

const sortedPosts = posts.sort(
  (a, b) =>
    new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);
---

<PageLayout>
  <PageMeta title={`Blog | ${SITE_TITLE}`} slot="meta" pagePath="/blog" />
  <section slot="main" class="pt-8">
    <h2 class="font-bold text-text-muted text-xs tracking-[0.2em] uppercase mb-6">
      Artículos
    </h2>
    <ul class="unset">
      {
        sortedPosts.map((post) => {
          const slug = post.id.replace(/\.mdoc$/, "");
          const formattedDate = formatDate(post.data.date);
          return (
            <li class="[&>*]:p-0 border-b border-text-muted/10 last:border-b-0">
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 py-3 sm:py-4 group">
                <div class="title">
                  {post.data.external ? (
                    <a
                      href={post.data.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="unset
                        transition-[background-size] duration-300
                        bg-gradient-to-r bg-left-bottom bg-no-repeat
                        bg-[length:0%_55%] hover:bg-[length:100%_55%] dark:bg-[length:0%_2px] hover:dark:bg-[length:100%_2px]
                        from-primary-blue to-primary-blue dark:from-primary-blue dark:to-primary-blue
                      "
                    >
                      <span>{post.data.title}</span>
                      <i class="ml-1.5 text-[11px] fa-solid fa-up-right-from-square opacity-60" />
                    </a>
                  ) : (
                    <a
                      href={`/blog/${slug}`}
                      transition:name={`post-title-${slug}`}
                      class="unset
                        transition-[background-size] duration-300
                        bg-gradient-to-r bg-left-bottom bg-no-repeat
                        bg-[length:0%_55%] hover:bg-[length:100%_55%] dark:bg-[length:0%_2px] hover:dark:bg-[length:100%_2px]
                        from-primary-blue to-primary-blue dark:from-primary-blue dark:to-primary-blue
                      "
                    >
                      {post.data.title}
                    </a>
                  )}
                </div>
                <time
                  datetime={post.data.date.toISOString()}
                  class="text-text-muted text-sm tabular-nums shrink-0"
                >
                  {formattedDate}
                </time>
              </div>
            </li>
          );
        })
      }
    </ul>
  </section>
</PageLayout>
